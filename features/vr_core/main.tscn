; ====================================================================
; Sprint 10 — Consultorio + libro en la mano
; ====================================================================

; Escenario del consultorio (oficina, escritorio, silla, iluminacion).
[node name="Consultorio" parent="." instance=ExtResource("4_consultorio")]

; Libro 3D anclado al controller derecho. Se mueve fisicamente con la mano.
; La escala del GLTF original es grande (~13 unidades de ancho); se reduce
; a un tamano de libro/revista comodo de leer en VR (~40 cm de ancho). Un
; libro algo mas grande aumenta los pixeles-por-grado de cada glifo, lo que
; compensa el bajo PPD del panel del Quest y reduce el pixelado del texto a
; distancia. Ajustar en el inspector si hace falta.
[node name="BookHolder" type="Node3D" parent="XROrigin3D/RightHand"]
script = ExtResource("6_book_holder")
post_process_quad_path = NodePath("../../XRCamera3D/PostProcessQuad")
xr_camera_path = NodePath("../../XRCamera3D")
book_node_path = NodePath("BookMesh")

[node name="BookMesh" parent="XROrigin3D/RightHand/BookHolder" instance=ExtResource("5_book")]
